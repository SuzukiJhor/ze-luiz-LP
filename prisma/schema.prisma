
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PostSection {
  POESIA
  DOCENCIA
  MUSICA
}

model Post {
  id        Int         @id @default(autoincrement())
  title     String
  subtitle  String? 
  content   String      @db.Text 
  section   PostSection @default(POESIA)
  category  String
  published Boolean     @default(false)

  coverImage String?
  document   String?
  audio      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posts")
}
